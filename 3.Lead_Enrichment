    {
      "parameters": {
        "jsCode": "const email = $json.email || \"\";\n\nif (!email.includes('@')) {\n  return [{ ...$json, domain: null, companyName: \"Unknown\", isPersonal: true }];\n}\n\nconst domain = email.split('@')[1].toLowerCase();\n\nconst personalDomains = [\n  \"gmail.com\", \"yahoo.com\", \"hotmail.com\", \"outlook.com\",\n  \"icloud.com\", \"proton.me\", \"protonmail.com\", \"me.com\",\n  \"aol.com\", \"live.com\"\n];\n\n// Detect personal email\nconst isPersonal = personalDomains.includes(domain);\n\n// Company name logic\nlet companyName;\n\n// If personal email → use a fallback label\nif (isPersonal) {\n  companyName = \"Personal email (no company)\";\n} else {\n  // Convert domain (microsoft.com → Microsoft)\n  const root = domain.split('.')[0];\n  companyName = root.charAt(0).toUpperCase() + root.slice(1);\n}\n\n// Output everything cleanly\nreturn [{\n  ...$json,\n  domain,\n  isPersonal,\n  companyName\n}];\n"
      },
