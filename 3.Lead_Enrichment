    {
      "parameters": {
        "jsCode": "const apollo = $json[0] || {};\nconst org = $input.first().json.organization || {};\n\nlet score = 0;\nlet reasons = [];\n\nif (org.estimated_num_employees) {\n  const employees = org.estimated_num_employees;\n\n  if (employees > 5000) { score += 30; reasons.push(\"Large enterprise\"); }\n  else if (employees > 1000) { score += 25; reasons.push(\"Mid-large company\"); }\n  else if (employees > 200) { score += 20; reasons.push(\"Growing company\"); }\n  else if (employees > 20) { score += 10; reasons.push(\"Small company\"); }\n  else { score += 5; reasons.push(\"Tiny company\"); }\n} else {\n  reasons.push(\"Unknown company size\");\n}\n\n\nconst industry = (org.industry || org.industries?.[0] || \"\").toLowerCase();\n\nif (\n  industry.includes(\"software\") ||\n  industry.includes(\"technology\") ||\n  industry.includes(\"ai\") ||\n  industry.includes(\"research\") ||       \n  industry.includes(\"development\") ||\n  industry.includes(\"engineering\")\n) {\n  score += 20;\n  reasons.push(\"Relevant industry: tech / AI / research / engineering\");\n}\n\nif (industry.includes(\"consulting\")) {\n  score += 10;\n  reasons.push(\"Consulting industry (automation-friendly)\");\n}\n\n\nif (org.total_funding && org.total_funding > 0) {\n  if (org.total_funding > 1_000_000_000) {\n    score += 25;\n    reasons.push(\"Heavily funded company\");\n  } else if (org.total_funding > 100_000_000) {\n    score += 15;\n    reasons.push(\"Well funded\");\n  } else if (org.total_funding > 10_000_000) {\n    score += 10;\n    reasons.push(\"Moderately funded\");\n  }\n}\n\n\nlet onlinePresence = 0;\n\nif (org.linkedin_url) onlinePresence += 1;\nif (org.twitter_url)  onlinePresence += 1;\nif (org.facebook_url) onlinePresence += 1;\nif (org.website_url)  onlinePresence += 1;\n\nscore += onlinePresence * 3;\n\nif (onlinePresence >= 3) {\n  reasons.push(\"Strong online presence\");\n} else if (onlinePresence >= 1) {\n  reasons.push(\"Basic online presence\");\n}\n\n// Normalize score\nif (score > 100) score = 100;\n\n// Lead quality label\nlet quality = \"low\";\nif (score >= 75) quality = \"high\";\nelse if (score >= 40) quality = \"medium\";\n\n// Output\nreturn [{\n  score,\n  quality,\n  reasons,\n  companyName: org.name || null,\n  industry: org.industry || null,\n  employees: org.estimated_num_employees || null,\n  domain: org.primary_domain || null,\n  website: org.website_url || null,\n  funding: org.total_funding || null,\n  raw: org\n}];\n"
      },
