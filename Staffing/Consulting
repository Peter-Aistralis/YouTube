    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nfor (let item of items) {\n  let text = item.json.opgekuist || \"\";\n\n  const postNavText = text.split(/FAQ\\s*\\[.*?\\]/i).pop() || \"\";\n  const lines = postNavText.trim().split('\\n').map(l => l.trim()).filter(l => l.length > 0);\n\n  const extract = (regex, source) => {\n    const match = source.match(regex);\n    return match ? match[1].trim() : null;\n  };\n\n  const cleanGarbage = (rawText) => {\n    let cleaned = rawText;\n    cleaned = cleaned.replace(/\\[https?:\\/\\/[^\\]]+\\]/g, '');\n    const navTerms = /Home|Opdrachten|Professionals|Zzp’ers|Leveranciers|Opdrachtgevers|Over ons|Werken bij|Diensten|Verzekeringen|Kennis|CAO wijziging|Wet DBA|Nieuws|Webinars|Contact|FAQ|Inschrijven|Login|Inloggen|Stel een vraag|Reageer op deze opdracht/gi;\n    \n    return cleaned.split('\\n')\n      .filter(line => !navTerms.test(line.trim()))\n      .filter(line => line.trim().length > 0)\n      .join('\\n');\n  };\n\n  const fullyCleanedText = cleanGarbage(text);\n\n  const extractSection = (startLabel, endLabel, source) => {\n    const regex = new RegExp(`(?:^|\\\\n)(?:${startLabel})[^\\\\n]*\\\\s*(?:\\\\n|$)([\\\\s\\\\S]*?)(?=(?:^|\\\\n)(?:${endLabel})|$)`, 'i');\n    const match = source.match(regex);\n    if (match && match[1]) {\n      return match[1].trim();\n    }\n    return null;\n  };\n\n  // ========== FALLBACK VOOR KNOCK-OUTCRITERIA (INCLUSIEF TARIEF) ==========\n  const extractKnockOutMetFallback = (source) => {\n    // Eerst proberen met standaard extractie\n    let result = extractSection(\"Vereisten / knock-outcriteria\", \"Gunningscriteria\", source);\n    if (result && result.length > 20) return result;\n    \n    // Fallback 1: zoek naar \"Uurtarief maximaal € XXX\"\n    const tariefMatch = source.match(/Uurtarief maximaal\\s*€\\s*(\\d+(?:[,-]\\d+)?)/i);\n    if (tariefMatch) {\n      return `3. Uurtarief maximaal € ${tariefMatch[1]} exclusief btw`;\n    }\n    \n    // Fallback 2: zoek naar de hele knock-out sectie met variabele schrijfwijze\n    const knockoutMatch = source.match(/Vereisten\\s*\\/\\s*knock-outcriteria[\\s\\S]*?(?=Gunningscriteria|Competenties|$)/i);\n    if (knockoutMatch && knockoutMatch[0].length > 50) {\n      return knockoutMatch[0].replace(/^Vereisten\\s*\\/\\s*knock-outcriteria\\s*/i, '').trim();\n    }\n    \n    // Fallback 3: zoek naar genummerde vereisten (1., 2., 3., etc.)\n    const genummerdeMatch = source.match(/(?:^|\\n)(?:\\d+\\.\\s.*?(?:\\n|$)){3,}/i);\n    if (genummerdeMatch && genummerdeMatch[0].includes('uur') && genummerdeMatch[0].includes('€')) {\n      return genummerdeMatch[0].trim();\n    }\n    \n    return \"\";\n  };\n\n  // ========== FALLBACK FUNCTIE VOOR WERKZAAMHEDEN ==========\n  const extractWerkzaamhedenMetFallback = (source) => {\n    let result = extractSection(\"Projecten en Werkzaamheden\", \"Vereisten\", source);\n    if (result && result.length > 50) return result;\n    \n    const watGaJeDoenMatch = source.match(/Wat ga je doen\\?[\\s]*([\\s\\S]*?)(?=(?:Vereisten|Vereisten \\/ knock-outcriteria|Competenties|$))/i);\n    if (watGaJeDoenMatch && watGaJeDoenMatch[1].trim().length > 50) {\n      return watGaJeDoenMatch[1].trim();\n    }\n    \n    const concreetMatch = source.match(/Wat je concreet gaat doen, is:[\\s]*([\\s\\S]*?)(?=(?:Vereisten|Vereisten \\/ knock-outcriteria|Competenties|$))/i);\n    if (concreetMatch && concreetMatch[1].trim().length > 50) {\n      return concreetMatch[1].trim();\n    }\n    \n    const verantwoordelijkMatch = source.match(/Je bent verantwoordelijk voor[\\s]*([\\s\\S]*?)(?=(?:Vereisten|Vereisten \\/ knock-outcriteria|Competenties|$))/i);\n    if (verantwoordelijkMatch && verantwoordelijkMatch[1].trim().length > 50) {\n      return verantwoordelijkMatch[1].trim();\n    }\n    \n    return \"\";\n  };\n  \n  // ========== FALLBACK FUNCTIE VOOR ORGANISATIE ==========\n  const extractOrganisatieMetFallback = (source) => {\n    let result = extractSection(\"Organisatie\", \"Opdracht\", source);\n    if (result && result.length > 30 && !result.includes(\"Stap\")) return result;\n    \n    const wieZijnWijMatch = source.match(/Wie zijn wij[\\s]*([\\s\\S]*?)(?=(?:Opdracht|Wat ga je doen|Vereisten|$))/i);\n    if (wieZijnWijMatch && wieZijnWijMatch[1].trim().length > 30) {\n      let orgText = wieZijnWijMatch[1].trim();\n      orgText = orgText.split(/\\n\\s*\\n/)[0];\n      if (!orgText.includes(\"Stap\")) return orgText;\n    }\n    \n    return \"\";\n  };\n  \n  // ========== FALLBACK FUNCTIE VOOR OPDRACHT ==========\n  const extractOpdrachtMetFallback = (source) => {\n    let result = extractSection(\"Opdracht\", \"Projecten en Werkzaamheden|Wat ga je doen\", source);\n    if (result && result.length > 30 && !result.includes(\"Stap\")) return result;\n    \n    const afdelingMatch = source.match(/Afdeling[\\s]*([\\s\\S]*?)(?=(?:Opdracht|Wat ga je doen|Vereisten|$))/i);\n    if (afdelingMatch && afdelingMatch[1].trim().length > 30) {\n      let afdelingText = afdelingMatch[1].trim();\n      afdelingText = afdelingText.split(/\\n\\s*\\n/)[0];\n      if (!afdelingText.includes(\"Stap\")) return afdelingText;\n    }\n    \n    return \"\";\n  };\n\n  const functieschaal = extractSection(\"Functieschaal|Schaal\", \"Fee Flextender|Benodigd aantal|CV-eisen\", text) || \"Niet vermeld\";\n  const feeFlextender = extractSection(\"Fee Flextender\", \"Benodigd aantal|CV-eisen|Planning\", text) || \"Niet vermeld\";\n\n  // GEBRUIK DE NIEUWE FUNCTIES\n  const knockOutCriteria = extractKnockOutMetFallback(text);\n  const org = extractOrganisatieMetFallback(fullyCleanedText);\n  const opdracht = extractOpdrachtMetFallback(fullyCleanedText);\n  const werkzaamheden = extractWerkzaamhedenMetFallback(fullyCleanedText);\n  \n  let aantalProfessionals = null;\n  const benodigdIndex = text.search(/Benodigd aantal professionals/i);\n  if (benodigdIndex !== -1) {\n    const substring = text.substring(benodigdIndex, benodigdIndex + 100);\n    const getalMatch = substring.match(/(\\d+)/);\n    if (getalMatch) {\n      aantalProfessionals = parseInt(getalMatch[1]);\n    }\n  }\n  \n  // Bepaal of er een tarief is gevonden (voor de logging/debug)\n  const heeftTarief = knockOutCriteria.includes('€') && knockOutCriteria.match(/\\d+/) !== null;\n  \n  const aiText = `ORGANISATIE:\\n${org}\\n\\nOPDRACHT:\\n${opdracht}\\n\\nWERKZAAMHEDEN & RESULTATEN:\\n${werkzaamheden}\\n\\nVEREISTEN / KNOCK-OUTCRITERIA:\\n${knockOutCriteria}\\n\\nTARIEF INFO:\\n${functieschaal}\\n\\nFLEXTENDER FEE:\\n${feeFlextender}`;\n\n  output.push({\n    json: {\n      title: item.json.title || lines[0],\n      locatie: item.json.locatie || lines[1],\n      details: {\n        aanvraagnummer: extract(/Aanvraagnummer\\s+(\\d+)/, text),\n        duur: extract(/Duur\\s+(.*?)\\n/, text),\n        opties_verlenging: extract(/Opties verlenging\\s+(.*?)\\n/, text),\n        uren_per_week: extract(/Uren per week\\s+(.*?)\\n/, text),\n        das_opdracht: extract(/DAS opdracht\\s+(.*?)\\n/, text),\n        start: extract(/Start\\s+(.*?)\\n/, text),\n        opleidingsniveau: extract(/Opleidingsniveau\\s+(.*?)\\n/, text),\n        regio: extract(/Regio\\s+(.*?)\\n/, text),\n        einde_inschrijfdatum: extract(/Einde inschrijfdatum\\s+(.*?)(?:\\s+agenda|$)/, text)\n      },\n      secties: {\n        aantal_professionals: aantalProfessionals,\n        vereisten: knockOutCriteria || null,\n        gunningscriteria: extractSection(\"Gunningscriteria\", \"Geef in het cv duidelijk aan|Competenties\", text),\n        competenties: extractSection(\"Competenties\", \"Beoordeling|Benodigd aantal\", text),\n        cv_eisen: extractSection(\"(?:CV-eisen|Offerte eisen)\", \"Werkdagen|Planning|Overige informatie\", text),\n        planning: extractSection(\"Planning\", \"Overige informatie|Meer informatie\", text),\n        Functieschaal: functieschaal,\n        Fee_Flextender: feeFlextender,\n        heeft_tarief: heeftTarief\n      },\n      formatted_text_voor_ai: aiText.trim()\n    }\n  });\n}\n\nreturn output;"
      },
