      "parameters": {
        "jsCode": "const items = $input.all();\nconst output = [];\n\nfor (let item of items) {\n  let text = item.json.Clean_text || \"\";\n\n  // 1. URL Extractie (Regex zoekt naar de link na de specifieke zin)\n  const urlRegex = /Reageer via deze link op de opdracht:\\s*(https?:\\/\\/[^\\s]+)/i;\n  const match = text.match(urlRegex);\n  const opdrachtUrl = match ? match[1].replace(/[.\\]]$/, '') : null;\n\n  // 2. Schoonmaken van de tekst (zoals voorheen)\n  text = text.replace(/\\[.*?\\]/g, '');\n  \n  // Verwijder headers/socials\n  const headerGarbage = [\n    /info@flextender\\.nl/gi,\n    /https:\\/\\/www\\.youtube\\.com\\/[^\\n]+/gi,\n    /https:\\/\\/www\\.linkedin\\.com\\/[^\\n]+/gi,\n    /http:\\/\\/www\\.flextender\\.nl/gi\n  ];\n  headerGarbage.forEach(regex => { text = text.replace(regex, ''); });\n\n  const labels = [\n    \"Aanvraagnummer:\", \"Functietitel:\", \"Opdrachtgever:\", \"Duur:\", \n    \"Optie tot verlenging:\", \"Uren per week:\", \"Aanvang:\", \n    \"Opleidingsniveau:\", \"Regio:\", \"Verloopt op:\"\n  ];\n\n  labels.forEach(label => {\n    const regex = new RegExp(`([^\\\\n])(${label})`, 'g');\n    text = text.replace(regex, '$1\\n$2'); \n    text = text.replace(new RegExp(`${label}\\\\s*`, 'g'), `${label} `);\n  });\n\n  // Specifieke plak-fixes\n  text = text.replace(/([a-z])(Verloopt op:)/gi, '$1\\n$2');\n  text = text.replace(/([a-z])(Uren per week:)/gi, '$1\\n$2');\n\n  // 3. Output opbouwen (Enkel de gevraagde velden)\n  output.push({\n    json: {\n      Formatted_Text: text.trim(),\n      Opdracht_URL: opdrachtUrl\n    }\n  });\n}\n\nreturn output;"
      },
